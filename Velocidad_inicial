    init_pos=-4e-9
)

field = MovingChargesField(charge)

# ============================================================
# DOMINIO
# ============================================================

xmin = -1.0e-8
xmax =  1.0e-8

ymin = -1.0e-8
ymax =  1.0e-8

# ============================================================
# MALLA DEL MAPA DE CALOR (ALTA RESOLUCIÓN)
# ============================================================

N_heat = 151

xh = np.linspace(xmin, xmax, N_heat)
yh = np.linspace(ymin, ymax, N_heat)

Xh2D, Yh2D = np.meshgrid(xh, yh)

Xh = Xh2D[np.newaxis, :, :]
Yh = Yh2D[np.newaxis, :, :]
Zh = np.zeros_like(Xh)

# ============================================================
# MALLA DE LOS VECTORES (BAJA RESOLUCIÓN)
# ============================================================

N_vec = 25

xv = np.linspace(xmin, xmax, N_vec)
yv = np.linspace(ymin, ymax, N_vec)

Xv2D, Yv2D = np.meshgrid(xv, yv)

Xv = Xv2D[np.newaxis, :, :]
Yv = Yv2D[np.newaxis, :, :]
Zv = np.zeros_like(Xv)

# ============================================================
# FIGURA
# ============================================================

fig, ax = plt.subplots(figsize=(8, 8))

ax.set_xlim(xmin, xmax)
ax.set_ylim(ymin, ymax)

ax.set_aspect('equal')

ax.set_xlabel("x (m)")
ax.set_ylabel("y (m)")

# ============================================================
# CAMPO INICIAL PARA EL HEATMAP
# ============================================================

t0 = 0.0

Ex_h, Ey_h, Ez_h = field.calculate_E(
    t0,
    Xh,
    Yh,
    Zh,
    plane=True
)

Emag = np.sqrt(Ex_h**2 + Ey_h**2)

Emag = np.nan_to_num(
    Emag,
    nan=0.0,
    posinf=0.0,
    neginf=0.0
)

# ============================================================
# ESCALA LOGARÍTMICA
# ============================================================

Emag_plot = np.log10(Emag + 1e-30)

vmin = np.percentile(Emag_plot, 5)
vmax = np.percentile(Emag_plot, 99.5)

# ============================================================
# HEATMAP
# ============================================================

heatmap = ax.imshow(
    Emag_plot,
    extent=[xmin, xmax, ymin, ymax],
    origin='lower',
    cmap='inferno',
    interpolation='bicubic',
    vmin=vmin,
    vmax=vmax
)

cbar = plt.colorbar(heatmap)
cbar.set_label(r'$\log_{10}|E|$')

# ============================================================
# CAMPO INICIAL PARA LOS VECTORES
# ============================================================

Ex_v, Ey_v, Ez_v = field.calculate_E(
    t0,
    Xv,
    Yv,
    Zv,
    plane=True
)

Emag_v = np.sqrt(Ex_v**2 + Ey_v**2)

Ex_plot = Ex_v / (Emag_v + 1e-30)
Ey_plot = Ey_v / (Emag_v + 1e-30)

quiver = ax.quiver(
    Xv2D,
    Yv2D,
    Ex_plot,
    Ey_plot,
    color='white',
    pivot='mid',
    scale=25
)

# ============================================================
# CARGA
# ============================================================

t0_array = np.array([0.0])

x0 = charge.xpos(t0_array)
y0 = charge.ypos(t0_array)

if np.isscalar(x0):
    x0 = x0
else:
    x0 = x0[0]

if np.isscalar(y0):
    y0 = y0
else:
    y0 = y0[0]

charge_dot, = ax.plot(
    x0,
    y0,
    'ro',
    markersize=5
)

# ============================================================
# TEXTO
# ============================================================

time_text = ax.text(
    0.02,
    0.96,
    '',
    transform=ax.transAxes,
    color='white'
)

# ============================================================
# TIEMPO
# ============================================================

dt = 1e-19

# ============================================================
# ANIMACIÓN
# ============================================================

def update(frame):

    t = frame * dt

    # --------------------------------------------------------
    # HEATMAP (alta resolución)
    # --------------------------------------------------------

    Ex_h, Ey_h, Ez_h = field.calculate_E(
        t,
        Xh,
        Yh,
        Zh,
        plane=True
    )

    Emag = np.sqrt(Ex_h**2 + Ey_h**2)

    Emag = np.nan_to_num(
        Emag,
        nan=0.0,
        posinf=0.0,
        neginf=0.0
    )

    Emag_plot = np.log10(Emag + 1e-30)

    heatmap.set_array(Emag_plot)

    # --------------------------------------------------------
    # VECTORES (baja resolución)
    # --------------------------------------------------------

    Ex_v, Ey_v, Ez_v = field.calculate_E(
        t,
        Xv,
        Yv,
        Zv,
        plane=True
    )

    Emag_v = np.sqrt(Ex_v**2 + Ey_v**2)

    Ex_plot = Ex_v/(Emag_v + 1e-30)
    Ey_plot = Ey_v/(Emag_v + 1e-30)

    quiver.set_UVC(
        Ex_plot,
        Ey_plot
    )

    # --------------------------------------------------------
    # POSICIÓN DE LA CARGA
    # --------------------------------------------------------

    xq = charge.xpos(np.array([t]))
    yq = charge.ypos(np.array([t]))

    if not np.isscalar(xq):
        xq = xq[0]

    if not np.isscalar(yq):
        yq = yq[0]

    charge_dot.set_data(
        [xq],
        [yq]
    )

    time_text.set_text(
        f"t = {t:.2e} s"
    )

    return (
        heatmap,
        quiver,
        charge_dot,
        time_text
    )

# ============================================================
# CREAR ANIMACIÓN
# ============================================================

anim = FuncAnimation(
    fig,
    update,
    frames=300,
    interval=40,
    blit=False
)






plt.tight_layout()


from matplotlib.animation import PillowWriter

anim.save(
    r"C:\Users\Usuario\Desktop\campo_electrico.gif",
    writer=PillowWriter(fps=25)
)



